        "id": 190080456740311054,
        "key": null,
        "code_repo_id": null,
        "ui_schema": {
            "displayString": "$config.app().sensor_name",
            "hidden": "$config.app().hidden:boolean:false:boolean:false",
            "position": "$config.app().dv_app_position:number:100",
            "icon": null,
            "colour": null,
            "defaultOpen": "$config.app().dv_app_default_open:boolean",
            "type": "uiApplication",
            "name": "$config.app().APP_KEY",
            "children": {
                "distance": {
                    "name": "distance",
                    "type": "uiVariable",
                    "displayString": "Distance",
                    "showActivity": true,
                    "position": 51,
                    "hidden": false,
                    "units": "m",
                    "varType": "float",
                    "currentValue": "$tag.app().distance_m:number:null",
                    "decPrecision": 2,
                    "live": true
                },
                "no_communication_with_sensor": {
                    "name": "no_communication_with_sensor",
                    "type": "uiWarningIndicator",
                    "displayString": "No communication with sensor",
                    "position": 52,
                    "hidden": "$tag.app().comms_ok:boolean:false",
                    "currentValue": "$cmds.app().no_communication_with_sensor",
                    "can_cancel": true
                },
                "weak_signal__distance_unreliable": {
                    "name": "weak_signal__distance_unreliable",
                    "type": "uiWarningIndicator",
                    "displayString": "Weak signal - distance unreliable",
                    "position": 53,
                    "hidden": "$tag.app().signal_warning_hidden:boolean:true",
                    "currentValue": "$cmds.app().weak_signal__distance_unreliable",
                    "can_cancel": true
                },
                "sensor_details": {
                    "name": "sensor_details",
                    "type": "uiSubmodule",
                    "displayString": "Sensor Details",
                    "showActivity": true,
                    "position": 57,
                    "hidden": false,
                    "children": {
                        "raw_distance": {
                            "name": "raw_distance",
                            "type": "uiVariable",
                            "displayString": "Raw Distance",
                            "showActivity": true,
                            "position": 54,
                            "hidden": false,
                            "units": "cm",
                            "varType": "float",
                            "currentValue": "$tag.app().distance_raw_cm:number:null",
                            "decPrecision": 0
                        },
                        "signal_strength": {
                            "name": "signal_strength",
                            "type": "uiVariable",
                            "displayString": "Signal Strength",
                            "showActivity": true,
                            "position": 55,
                            "hidden": false,
                            "varType": "float",
                            "currentValue": "$tag.app().signal_strength:number:null",
                            "decPrecision": 0,
                            "ranges": [
                                {
                                    "min": 0,
                                    "max": 40,
                                    "colour": "yellow",
                                    "show_on_graph": true,
                                    "label": "Weak"
                                },
                                {
                                    "min": 40,
                                    "max": 3500,
                                    "colour": "green",
                                    "show_on_graph": true,
                                    "label": "Good"
                                }
                            ]
                        },
                        "last_read": {
                            "name": "last_read",
                            "type": "uiTimestamp",
                            "displayString": "Last Read",
                            "showActivity": true,
                            "position": 56,
                            "hidden": false,
                            "varType": "timestamp",
                            "currentValue": "$tag.app().last_read:number:null"
                        }
                    }
                }
            }
        },
