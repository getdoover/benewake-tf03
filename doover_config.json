        "repo_branch": "main",
        "staging_config": {},
        "lambda_config": {},
        "owner_org_id": null,
        "container_registry_profile_id": 93955828574386692,
        "organisation_id": null,
        "config_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "",
            "title": "$default",
            "type": "object",
            "properties": {
                "sensor_name": {
                    "title": "Sensor Name",
                    "x-name": "sensor_name",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Friendly name shown on the dashboard.",
                    "default": "TF03 LiDAR",
                    "x-position": 0
                },
                "comms_mode": {
                    "enum": [
                        "serial",
                        "modbus"
                    ],
                    "title": "Comms Mode",
                    "x-name": "comms_mode",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "How to read the sensor. 'serial' reads the TF03's native RS485/UART streaming output directly (factory default - no sensor setup needed). 'modbus' polls it over Modbus-RTU via the shared modbus_interface (requires Modbus to be enabled on the sensor first).",
                    "default": "serial",
                    "x-position": 1
                },
                "serial_port": {
                    "title": "Serial Port",
                    "x-name": "serial_port",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "(Serial mode) Serial device the TF03 is wired to, e.g. /dev/ttyAMA0, /dev/ttyUSB0. A pyserial URL such as socket://host:port is also accepted (used by the simulator).",
                    "default": "/dev/ttyAMA0",
                    "x-position": 2
                },
                "serial_baud": {
                    "title": "Serial Baud",
                    "x-name": "serial_baud",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "(Serial mode) Baud rate of the TF03 serial stream. Factory default is 115200 (8 data bits, no parity, 1 stop bit).",
                    "default": 115200,
                    "x-position": 3
                },
                "modbus_address": {
                    "title": "Modbus Address",
                    "x-name": "modbus_address",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "(Modbus mode) Modbus/RS485 slave address of the TF03. Factory default is 1. Valid range is 1-247.",
                    "default": 1,
                    "x-position": 4
                },
                "mounting_offset_metres": {
                    "title": "Mounting Offset Metres",
                    "x-name": "mounting_offset_metres",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Added to the raw measured distance for calibration (e.g. sensor recess or known bias). Usually 0.",
                    "default": 0.0,
                    "x-position": 5
                },
                "minimum_signal_strength": {
                    "title": "Minimum Signal Strength",
                    "x-name": "minimum_signal_strength",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Readings with signal strength below this are flagged as unreliable. The TF03 datasheet threshold is 40.",
                    "default": 40,
                    "x-position": 6
                },
                "maximum_valid_distance_metres": {
                    "title": "Maximum Valid Distance Metres",
                    "x-name": "maximum_valid_distance_metres",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Distances above this are treated as 'no target' / over-range. The TF03-100 measuring range is 100 m.",
                    "default": 100.0,
                    "x-position": 7
                },
                "modbus_config": {
                    "title": "Modbus Config",
                    "x-name": "modbus_config",
                    "x-hidden": false,
                    "type": "object",
                    "x-required": true,
                    "x-position": 8,
                    "properties": {
                        "bus_type": {
                            "enum": [
                                "serial",
                                "tcp"
