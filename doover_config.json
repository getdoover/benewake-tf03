                                "number",
                                "null"
                            ],
                            "x-required": false,
                            "default": 0.3,
                            "x-position": 9
                        },
                        "tcp_uri": {
                            "title": "TCP URI",
                            "x-name": "tcp_uri",
                            "x-hidden": false,
                            "type": [
                                "string",
                                "null"
                            ],
                            "x-required": false,
                            "default": "127.0.0.1:5000",
                            "x-position": 10
                        },
                        "tcp_timeout": {
