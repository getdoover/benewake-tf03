                            "x-hidden": false,
                            "type": [
                                "integer",
                                "null"
                            ],
                            "x-required": false,
                            "default": 1,
                            "x-position": 8
                        },
                        "serial_timeout": {
                            "title": "Serial Timeout",
                            "x-name": "serial_timeout",
                            "x-hidden": false,
