                                "null"
                            ],
                            "x-required": false,
                            "default": "default",
                            "x-position": 2
                        },
                        "serial_port": {
                            "title": "Serial Port",
                            "x-name": "serial_port",
                            "x-hidden": false,
                            "type": [
                                "string",
                                "null"
                            ],
                            "x-required": false,
                            "default": "/dev/ttyAMA0",
                            "x-position": 3
                        },
                        "serial_baud": {
                            "title": "Serial Baud",
                            "x-name": "serial_baud",
                            "x-hidden": false,
                            "type": [
                                "integer",
                                "null"
                            ],
                            "x-required": false,
                            "default": 115200,
                            "x-position": 4
                        },
                        "serial_method": {
                            "enum": [
                                "rtu",
                                "ascii",
                                "socket",
                                "tls"
                            ],
