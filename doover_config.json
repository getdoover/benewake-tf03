{
    "benewake_tf03": {
        "name": "benewake_tf03",
        "display_name": "Benewake TF03 LiDAR",
        "type": "DEV",
        "visibility": "PUB",
        "allow_many": true,
        "description": "Read distance from a Benewake TF03-100 RS485 LiDAR over native RS485 serial streaming or Modbus-RTU.",
        "long_description": "README.md",
        "depends_on": [
            "platform_interface",
            "modbus_interface"
        ],
        "owner_org_key": "",
        "image_name": "ghcr.io/getdoover/benewake-tf03:main",
        "container_registry_profile_key": "",
        "build_args": "--platform linux/amd64,linux/arm64",
        "owner_org": "36a22e32-ab81-4a39-b400-869d532a052d",
        "container_registry_profile": "88953909-e9c4-4f81-9ec0-56239d4b0a2e",
        "repo_branch": "main",
        "staging_config": {},
        "lambda_config": {},
        "owner_org_id": null,
        "container_registry_profile_id": 93955828574386692,
        "organisation_id": null,
        "config_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "",
            "title": "Application Config",
            "type": "object",
            "properties": {
                "sensor_name": {
                    "title": "Sensor Name",
                    "x-name": "sensor_name",
                    "x-hidden": false,
                    "type": "string",
                    "description": "Friendly name shown on the dashboard.",
                    "default": "TF03 LiDAR"
                },
                "comms_mode": {
                    "enum": [
                        "serial",
                        "modbus"
                    ],
                    "title": "Comms Mode",
                    "x-name": "comms_mode",
                    "x-hidden": false,
                    "type": "string",
                    "description": "How to read the sensor. 'serial' reads the TF03's native RS485/UART streaming output directly (factory default - no sensor setup needed). 'modbus' polls it over Modbus-RTU via the shared modbus_interface (requires Modbus to be enabled on the sensor first).",
                    "default": "serial"
                },
                "serial_port": {
                    "title": "Serial Port",
                    "x-name": "serial_port",
                    "x-hidden": false,
                    "type": "string",
                    "description": "(Serial mode) Serial device the TF03 is wired to, e.g. /dev/ttyAMA0, /dev/ttyUSB0. A pyserial URL such as socket://host:port is also accepted (used by the simulator).",
                    "default": "/dev/ttyAMA0"
                },
                "serial_baud": {
                    "title": "Serial Baud",
                    "x-name": "serial_baud",
                    "x-hidden": false,
                    "type": "integer",
                    "description": "(Serial mode) Baud rate of the TF03 serial stream. Factory default is 115200 (8 data bits, no parity, 1 stop bit).",
                    "default": 115200
                },
                "modbus_address": {
                    "title": "Modbus Address",
                    "x-name": "modbus_address",
                    "x-hidden": false,
                    "type": "integer",
                    "description": "(Modbus mode) Modbus/RS485 slave address of the TF03. Factory default is 1. Valid range is 1-247.",
                    "default": 1
                },
                "mounting_offset_metres": {
                    "title": "Mounting Offset Metres",
                    "x-name": "mounting_offset_metres",
                    "x-hidden": false,
                    "type": "number",
                    "description": "Added to the raw measured distance for calibration (e.g. sensor recess or known bias). Usually 0.",
                    "default": 0.0
                },
                "minimum_signal_strength": {
                    "title": "Minimum Signal Strength",
                    "x-name": "minimum_signal_strength",
                    "x-hidden": false,
                    "type": "integer",
                    "description": "Readings with signal strength below this are flagged as unreliable. The TF03 datasheet threshold is 40.",
                    "default": 40
                },
                "maximum_valid_distance_metres": {
                    "title": "Maximum Valid Distance Metres",
                    "x-name": "maximum_valid_distance_metres",
                    "x-hidden": false,
                    "type": "number",
                    "description": "Distances above this are treated as 'no target' / over-range. The TF03-100 measuring range is 100 m.",
                    "default": 100.0
                },
                "modbus_config": {
                    "title": "Modbus Config",
                    "x-name": "modbus_config",
                    "x-hidden": false,
                    "type": "object",
                    "properties": {
                        "bus_type": {
                            "enum": [
                                "serial",
                                "tcp"
                            ],
                            "title": "Bus Type",
                            "x-name": "bus_type",
                            "x-hidden": false,
                            "type": "string",
                            "default": "serial"
                        },
                        "name": {
                            "title": "Name",
                            "x-name": "name",
                            "x-hidden": false,
                            "type": "string",
                            "default": "default"
                        },
                        "serial_port": {
                            "title": "Serial Port",
                            "x-name": "serial_port",
                            "x-hidden": false,
                            "type": "string",
                            "default": "/dev/ttyAMA0"
                        },
                        "serial_baud": {
                            "title": "Serial Baud",
                            "x-name": "serial_baud",
                            "x-hidden": false,
                            "type": "integer",
                            "default": 115200
                        },
                        "serial_method": {
                            "enum": [
                                "rtu",
                                "ascii",
                                "socket",
                                "tls"
                            ],
                            "title": "Serial Method",
                            "x-name": "serial_method",
                            "x-hidden": false,
                            "type": "string",
                            "default": "rtu"
                        },
                        "serial_data_bits": {
                            "title": "Serial Data Bits",
                            "x-name": "serial_data_bits",
                            "x-hidden": false,
                            "type": "integer",
                            "default": 8
                        },
                        "serial_parity": {
                            "enum": [
                                "None",
                                "Even",
                                "Odd"
                            ],
                            "title": "Serial Parity",
                            "x-name": "serial_parity",
                            "x-hidden": false,
                            "type": "string",
                            "default": "None"
                        },
                        "serial_stop_bits": {
                            "title": "Serial Stop Bits",
                            "x-name": "serial_stop_bits",
                            "x-hidden": false,
                            "type": "integer",
                            "default": 1
                        },
                        "serial_timeout": {
                            "title": "Serial Timeout",
                            "x-name": "serial_timeout",
                            "x-hidden": false,
                            "type": "number",
                            "default": 0.3
                        },
                        "tcp_uri": {
                            "title": "TCP URI",
                            "x-name": "tcp_uri",
                            "x-hidden": false,
                            "type": "string",
                            "default": "127.0.0.1:5000"
                        },
                        "tcp_timeout": {
                            "title": "TCP Timeout",
                            "x-name": "tcp_timeout",
                            "x-hidden": false,
                            "type": "number",
                            "default": 2.0
                        }
                    },
                    "additionalElements": true,
                    "required": []
                }
            },
            "additionalElements": true,
            "required": [
                "modbus_config"
            ]
        },
